{
  "name": "unique-names-generator",
  "version": "4.7.1",
  "description": "Generate unique and memorable names",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint ./src",
    "test": "npm run format && npm run lint && jest --coverage",
    "test:watch": "jest --coverage --watchAll",
    "format": "prettier --write src/**/*.ts",
    "prebuild": "npm run format",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "prerelease": "npm run build",
    "release": "np"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "umd:main": "dist/index.global.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "source": "src/index.ts",
  "types": "dist/index.d.ts",
  "tags": [
    "name-generator",
    "unique-names",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "private": false,
  "author": "Andrea Sonny <andreasonny83@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreasonny83/unique-names-generator.git"
  },
  "bugs": {
    "url": "https://github.com/andreasonny83/unique-names-generator/issues"
  },
  "homepage": "https://github.com/andreasonny83/unique-names-generator#readme",
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@babel/preset-env": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.25.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "all-contributors-cli": "^6.26.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "np": "^10.2.0",
    "prettier": "^3.5.3",
    "prettier-eslint": "^16.4.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
